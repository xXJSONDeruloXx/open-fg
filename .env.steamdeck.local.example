# Copy to .env.steamdeck.local and fill in as needed.
# This file is gitignored.
#
# Once filled in, the full hardware regression suite runs automatically:
#
#   OMFG_LAYER_IMPL=rust bash scripts/run-layer-regression-suite.sh
#
# The script sources this file at startup. If STEAMDECK_PASS is empty or
# the file is missing, the Deck smoke suite is skipped (unit tests still run).
# The suite builds a Linux/amd64 .so via Docker, deploys it to the Deck over
# SSH/SCP, runs vkcube for all 19 modes, and asserts expected log markers.

STEAMDECK_HOST=192.168.0.241
STEAMDECK_USER=deck
STEAMDECK_PASS=
