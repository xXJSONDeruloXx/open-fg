# Copy to .env.android.local and fill in as needed.
# This file is gitignored.
#
# Once filled in, run the Android Bionic arm64 build:
#
#   bash scripts/build-android-bionic.sh
#
# The script sources this file at startup to locate the Android NDK.
# Requires Rust target: rustup target add aarch64-linux-android

# Path to the Android NDK root (the directory containing toolchains/).
# Example (Homebrew): /opt/homebrew/share/android-commandlinetools/ndk/27.3.13750724
# Example (Android Studio): $HOME/Library/Android/sdk/ndk/27.3.13750724
ANDROID_NDK_ROOT=$HOME/Library/Android/sdk/ndk/27.3.13750724

# Android API level to target (21 = Android 5.0+, covers all modern devices)
ANDROID_API_LEVEL=21
